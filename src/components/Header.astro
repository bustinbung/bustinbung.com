---
const pages: {title:string, url?: string}[]  = [
    {
        title: "home",
        url: "/",
    },
    {
        title: "about",
    },
    {
        title: "projects",
    },
    {
        title: "blog"
    }
]
---

<header>
    <ul class="unstyled-list">
        {
            pages.map(page => <li><a href={page.url ? page.url : `/${page.title}`} class="navbar-link">{page.title}</a></li>)
        }
    </ul>
</header>