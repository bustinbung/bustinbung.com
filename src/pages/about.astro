---
import { Image } from 'astro:assets';

import BaseLayout from '@layouts/BaseLayout.astro';
import Granim from '@components/Granim.astro';

import headshot from '@assets/img/headshot.jpg';

const onlinePresence = [
    {
        icon: 'fa-solid fa-envelope',
        url: 'mailto:justin@bustinbung.com'
    },
    {
        icon: 'fa-brands fa-github',
        url: 'https://github.com/bustinbung'
    },
    {
        icon: 'fa-brands fa-linkedin',
        url: 'https://linkedin.com/in/bustinbung'
    },
    {
        icon: 'fa-brands fa-square-instagram',
        url: 'https://instagram.com/bustinbung'
    },
    {
        icon: 'fa-brands fa-twitter',
        url: 'https://twitter.com/bustinbung'
    },
    {
        icon: 'fa-brands fa-youtube',
        url: 'https://www.youtube.com/@bustinbung'
    },
    {
        icon: 'fa-brands fa-spotify',
        url: 'https://open.spotify.com/user/31ww575syjxqf7h653q36evvbgeu?si=b48408449b544942'
    }
]
---

<BaseLayout pageTitle="about">
    <h1 class="page-header">about</h2>

    <div class="two-column">
        <div class="headshot-wrapper">
            <Image src={headshot} alt="Justin's headshot" height=248 />
        </div>

        <div>
            <p>Hi, I'm Justin Jung! I'm a second-year student at the University of Georgia pursuing a Bachelor of Arts in Entertainment and Media Studies with a certificate in New Media and a minor in Music.</p>

            <p>I work primarily as a video editor and motion graphics designer, but also have experience operating cameras and editing sound. I love visual storytelling, and hope I can pursue a career sharing the diverse stories and perspectives of the people around me.</p>

            <p>In my free time, I like to play video games, read, listen to music, and get bubble tea.</p>

            <p>If you'd like to get in touch, feel free to get in contact with me through any of the channels below. Thanks!</p>

            <hr>
            
            <h2>online presence:</h2>
            <ul class="unstyled-list">
                {onlinePresence.map(item => 
                    <li>
                        <a href={item.url} target="_blank" class="icon-link">
                            <i class={item.icon}/>
                        </a>
                    </li>
                )}
            </ul>
        </div>
    </div>
</BaseLayout>

<style>
    .two-column {
        display: flex;
        flex-direction: row;
    }

    .unstyled-list {
        display: inline-flex;
        justify-content: center;
        padding-block: 10px;
    }

    .icon-link {
        padding-inline: 5px;
        font-size: 25px;
    }

    .headshot-wrapper {
        display: inline;
        height: 100%;
    }

    img[alt="Justin's headshot"] {
        margin-right: 20px;
        float: left;
    }

    hr {
        border-top: var(--border) !important;
    }

    hr:before {
        content: none !important;
    }
    hr:after {
        content: none !important;
    }
</style>